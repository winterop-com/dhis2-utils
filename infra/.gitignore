# macOS
.DS_Store

# Database dump
*.sql.gz
# Exception: per-version e2e dumps under `infra/v{N}/dump.sql.gz` — committed
# Sierra Leone seed used by GitHub Actions and `make dhis2-run` out of the
# box. Real / production dumps under a different filename (like `prod.sql.gz`
# or `customer-backup.sql.gz`) stay ignored by the pattern above.
!v*/dump.sql.gz
# Temporary backup written by infra/scripts/codegen_all_versions.sh while
# the sweep swaps the committed dump out for an empty placeholder.
v*/dump.sql.gz.codegen-backup

# DHIS2 runtime data
home/logs/
home/files/
home/glowroot/
home/credentials/

# Credentials
.env
home/dhis-google-auth.json

# Notes
notes/

# Python / uv
.venv/
__pycache__/
*.pyc

# Playwright MCP runtime artifacts
.playwright-mcp/

# Verification screenshots taken during sessions
*.png
# Committed brand assets — applied by the e2e seed via `Dhis2Client.customize`
!login-customization/*.png

# Stray uv-init placeholder
main.py
