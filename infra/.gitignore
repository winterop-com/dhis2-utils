# macOS
.DS_Store

# Database dump
*.sql.gz
# Exception: the tiny e2e test dump IS committed so GitHub Actions can run the
# stack without any external secrets. Keep it small (few MB, 1–2 users + a
# sample dataset) — any real / production dumps under a different filename
# stay ignored by the pattern above.
!dhis.sql.gz
# Temporary backup written by infra/scripts/codegen_all_versions.sh while
# the sweep swaps the committed dump out for an empty placeholder.
dhis.sql.gz.codegen-backup

# DHIS2 runtime data
home/logs/
home/files/
home/glowroot/
home/credentials/

