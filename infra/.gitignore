# macOS
.DS_Store

# Database dump
*.sql.gz
# Exceptions:
# - `dhis-v<version>.sql.gz` — e2e test dumps (Norway tree + seeded data +
#   tracker + analytics) used by GitHub Actions and by `make dhis2-run` out
#   of the box. One file per DHIS2 major version we support.
# - `dhis-<version>.sql.gz` — per-version Flyway-bootstrapped empty-schema
#   dumps produced by codegen_all_versions.sh. Useful as a cheap restore
#   point for a specific DHIS2 version without any seeded data.
# Real / production dumps under a different filename (like `prod.sql.gz` or
# `customer-backup.sql.gz`) stay ignored by the pattern above.
!dhis-*.sql.gz
# Temporary backup written by infra/scripts/codegen_all_versions.sh while
# the sweep swaps the committed dump out for an empty placeholder.
dhis-v*.sql.gz.codegen-backup

# DHIS2 runtime data
home/logs/
home/files/
home/glowroot/
home/credentials/

# Credentials
.env
home/dhis-google-auth.json

# Notes
notes/

# Python / uv
.venv/
__pycache__/
*.pyc

# Playwright MCP runtime artifacts
.playwright-mcp/

# Verification screenshots taken during sessions
*.png
# Committed brand assets — applied by the e2e seed via `Dhis2Client.customize`
!login-customization/*.png

# Stray uv-init placeholder
main.py
