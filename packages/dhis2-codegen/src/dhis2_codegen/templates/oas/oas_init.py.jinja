"""Flat re-export of every symbol emitted from /api/openapi.json."""
# ruff: noqa: E501

from __future__ import annotations

import sys

{% for name in enum_names %}
from ._enums import {{ name }}
{% endfor %}
{% for name in alias_names %}
from ._aliases import {{ name }}
{% endfor %}
{% for module_name, class_name in class_pairs %}
from .{{ module_name }} import {{ class_name }}
{% endfor %}

# Inject every generated class into every generated submodule's namespace so
# pydantic's forward-ref resolution — which looks up the class's `__module__`
# globals first — can find sibling classes without triggering import cycles.
# `_types_namespace=` alone isn't enough because pydantic's eval still checks
# globalns before locals, and TYPE_CHECKING-only imports leave globalns empty.
_classes = {
{% for _, class_name in class_pairs %}
    "{{ class_name }}": {{ class_name }},
{% endfor %}
}
_submodule_names = {
{% for module_name in submodule_names %}
    "{{ module_name }}",
{% endfor %}
}
for _name in _submodule_names:
    _m = sys.modules.get(f"{__name__}.{_name}")
    if _m is not None:
        _m.__dict__.update(_classes)
# Skip the eager model_rebuild() loop. Pydantic v2 lazily resolves forward
# references on first validate; trading a slightly-slower first call against
# ~900 ms of import-time class rebuilding pays back massively for any caller
# that doesn't immediately validate every model — `dhis2 --help`, MCP tool
# discovery, library scripts that touch a handful of models.
# for _cls in _classes.values():
#     _cls.model_rebuild()
del _classes, _submodule_names

__all__ = [
{% for name in all_names %}
    "{{ name }}",
{% endfor %}
]
